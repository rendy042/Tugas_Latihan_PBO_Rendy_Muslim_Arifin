<?xml version="1.0" encoding="utf-8"?>
<!-- File: activity_login.xml -->
<!-- Halaman Login - Aplikasi Kasir Toko Bangunan -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <!-- Judul Aplikasi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kasir Toko Bangunan"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Silakan login untuk memulai"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <!-- Kolom Input ID Kasir -->
    <EditText
        android:id="@+id/inputIdKasir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ID Kasir"
        android:inputType="text"
        android:layout_marginBottom="16dp" />

    <!-- Kolom Input Password -->
    <EditText
        android:id="@+id/inputPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Password"
        android:inputType="textPassword"
        android:layout_marginBottom="32dp" />

    <!-- Tombol Login -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Masuk"
        android:textSize="18sp" />

</LinearLayout>